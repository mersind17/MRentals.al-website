{
    "redirects": [
        {
            "source": "/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "www.mrentals.al"
                }
            ],
            "destination": "https://mrentals.al/$1",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/photos/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/(og-image.jpg|favicon-32.png|apple-touch-icon.png|icon-512.png)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=86400" }
            ]
        },
        {
            "source": "/(sitemap.xml|robots.txt)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=3600" }
            ]
        }
    ]
}
